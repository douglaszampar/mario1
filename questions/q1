<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dialogue Order</title>

<style>

body{
font-family:Arial;
background:#0E1D2E;
color:white;
padding:40px;
text-align:center;
}

h2{
margin-bottom:20px;
}

/* TIMER */

.timer{
width:100%;
height:18px;
background:#333;
border-radius:10px;
overflow:hidden;
margin-bottom:30px;
}

.bar{
height:100%;
width:100%;
background:#00e676;
}

/* LIST */

#list{
max-width:700px;
margin:auto;
}

.item{
background:#1f2f45;
padding:12px;
margin:8px 0;
border-radius:6px;
cursor:grab;
user-select:none;
}

/* RESULTS */

.correct{
background:#2e7d32;
}

.wrong{
background:#c62828;
}

button{
margin-top:20px;
padding:10px 25px;
font-size:18px;
cursor:pointer;
}

</style>
</head>

<body>

<h2>Put the dialogue in order</h2>

<div class="timer">
<div class="bar" id="bar"></div>
</div>

<div id="list"></div>

<button onclick="check()">Check</button>

<script>

/* =====================
PASTE YOUR DIALOGUE HERE
===================== */

const dialogue = [

"Helen: A cappuccino, please.",
"Barista 1: What's your name?",
"Helen: Helen.",
"Barista 1: Ellen?",
"Helen: No, Helen.",
"Barista 1: Helen. Ok."

]

/* ===================== */

const correct = [...dialogue]

let shuffled = [...dialogue].sort(()=>Math.random()-0.5)

const list = document.getElementById("list")

let dragged = null

/* CREATE ITEMS */

shuffled.forEach(text=>{

let div=document.createElement("div")

div.className="item"
div.innerText=text
div.draggable=true

div.addEventListener("dragstart",()=>{

dragged=div

})

div.addEventListener("dragover",(e)=>{

e.preventDefault()

})

div.addEventListener("drop",(e)=>{

e.preventDefault()

if(dragged && dragged!==div){

let temp = div.innerText
div.innerText = dragged.innerText
dragged.innerText = temp

}

})

list.appendChild(div)

})

/* CHECK ANSWERS */

function check(){

let items=document.querySelectorAll(".item")

items.forEach((item,i)=>{

if(item.innerText===correct[i]){

item.classList.add("correct")

}else{

item.classList.add("wrong")

}

})

}

/* TIMER */

let time=60
const bar=document.getElementById("bar")

const timer=setInterval(()=>{

time--

bar.style.width=(time/60*100)+"%"

if(time<=0){

clearInterval(timer)
check()

}

},1000)

</script>

</body>
</html>
